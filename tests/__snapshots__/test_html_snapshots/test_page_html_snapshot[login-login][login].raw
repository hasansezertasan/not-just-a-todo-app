        </div>
    

            

    
    
        
    

    
    
    
    
    

    <div class="form-group required"><label class="form-control-label" for="password">Password</label>
                
                    
                        <input class="form-control form-control" data-eye-close-class="fa-toggle-on" data-eye-open-class="fa-toggle-off" data-message="Show/Hide Password" data-placement="before" data-toggle="password" id="password" name="password" placeholder="Password" required type="password" value="">
                    
                <small class="form-text text-muted">Enter your password.</small>
        </div>
    

            

    
    

    
    
    
    
    

    
        
        
        
    

            
            
