# Copy to .env and fill in. Anything left commented out uses the default
# from src/app/config.py:Settings.

# --- Core ------------------------------------------------------------------
APP_ENV=development                                    # development | testing | production
SESSION_SECRET_KEY="change-me"                          # required when APP_ENV=production
PERMANENT_SESSION_LIFETIME_DAYS=7
SQLALCHEMY_DATABASE_URL="sqlite:///instance/db.sqlite3"
SESSION_COOKIE_SAMESITE=Lax                             # Lax | Strict | None
LOG_LEVEL=INFO

# --- Database pool (Postgres/MySQL only; SQLite ignores pool_size) ---------
# Sizing rule: pool_size ≈ GUNICORN_THREADS, max_overflow handles bursts.
# Total Postgres connections at peak = WEB_CONCURRENCY × (pool_size + max_overflow).
# Keep that below Postgres `max_connections` minus admin reserve.
# DB_POOL_PRE_PING=true
# DB_POOL_SIZE=5
# DB_POOL_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT_SECONDS=30
# DB_POOL_RECYCLE_SECONDS=3600
# DB_STATEMENT_TIMEOUT_MS=25000                          # Postgres only; see docs/operations.md

# --- Observability ---------------------------------------------------------
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
# METRICS_ENABLED=true
# OTEL_ENDPOINT=                                         # e.g. http://otel-collector:4317
# OTEL_SERVICE_NAME=not-just-a-todo-app

# --- Rate limiting ---------------------------------------------------------
# RATE_LIMIT_STORAGE_URI=memory://                      # use redis://… for multi-worker
# RATE_LIMIT_LOGIN="10 per minute"
# RATE_LIMIT_REGISTER="5 per hour"

# --- Dev only --------------------------------------------------------------
# DEBUG_TOOLBAR_ENABLED=true                            # Flask-DebugToolbar in development
# SQLALCHEMY_ECHO=true                                  # echo every SQL stmt to stdout
